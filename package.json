{
  "name": "creditcardmaster",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "init-db": "node --disable-warning=ExperimentalWarning src/seed.mjs",
    "search": "node --disable-warning=ExperimentalWarning src/cli.mjs search",
    "ask": "node --disable-warning=ExperimentalWarning src/cli.mjs ask",
    "bestcard": "node --disable-warning=ExperimentalWarning src/cli.mjs bestcard",
    "rakuten": "node --disable-warning=ExperimentalWarning src/cli.mjs rakuten",
    "add-offer": "node --disable-warning=ExperimentalWarning src/cli.mjs add-offer",
    "paste-offer": "node --disable-warning=ExperimentalWarning src/cli.mjs paste-offer",
    "watch": "node --disable-warning=ExperimentalWarning src/cli.mjs watch",
    "unwatch": "node --disable-warning=ExperimentalWarning src/cli.mjs unwatch",
    "watchlist": "node --disable-warning=ExperimentalWarning src/cli.mjs watchlist",
    "doc-monitor": "node --disable-warning=ExperimentalWarning src/cli.mjs doc-monitor",
    "doc-monitor-send": "node --disable-warning=ExperimentalWarning src/cli.mjs doc-monitor-send",
    "doc-monitor-status": "node --disable-warning=ExperimentalWarning src/cli.mjs doc-monitor-status",
    "wallet-strategy": "node --disable-warning=ExperimentalWarning src/cli.mjs wallet-strategy",
    "doctor": "node --disable-warning=ExperimentalWarning src/cli.mjs doctor",
    "expiring": "node --disable-warning=ExperimentalWarning src/cli.mjs expiring",
    "dedupe-offers": "node --disable-warning=ExperimentalWarning src/cli.mjs dedupe-offers",
    "status": "node --disable-warning=ExperimentalWarning src/cli.mjs status",
    "bot": "node --disable-warning=ExperimentalWarning src/bot.mjs",
    "public:check": "node --disable-warning=ExperimentalWarning scripts/public-release-check.mjs",
    "test:public": "CCM_DISTRIBUTION=public node --test test/dedupe-offers.test.mjs test/doc-monitor.test.mjs test/public.test.mjs",
    "test": "npm run test:public",
    "smoke": "node --disable-warning=ExperimentalWarning src/seed.mjs && node --disable-warning=ExperimentalWarning src/cli.mjs search restaurant && node --disable-warning=ExperimentalWarning src/cli.mjs search starbucks && node --disable-warning=ExperimentalWarning src/cli.mjs expiring 30"
  },
  "dependencies": {
    "discord.js": "^14.16.3"
  },
  "overrides": {
    "undici": "6.27.0"
  },
  "engines": {
    "node": ">=22.5"
  }
}
