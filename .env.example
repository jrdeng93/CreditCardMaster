# CreditCardMaster public defaults.
# Copy this file to .env, then fill only the sections you use.

# Distribution
# public = local assistant, manual/user-provided offers, public card benefits, and RSS news monitor.
CCM_DISTRIBUTION=public
OFFER_DB_PATH=./data/offers.sqlite

# Discord bot, used for /offers, /bestcard, and manual offers.
# Required if you want the mobile-first workflow.
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
# Required. The bot refuses to start when this is empty.
DISCORD_ALLOWED_USER_IDS=

# Discord webhook, used by credit-card news briefings.
# Either variable name works; keep both blank if you only use slash commands.
DISCORD_WEBHOOK_URL=
CREDITCARDMASTER_DISCORD_WEBHOOK_URL=

# Local LLM, used for better intent/category parsing when Ollama is available.
# CreditCardMaster still has deterministic fallbacks when this is unavailable.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_MS=10000
OFFER_DISABLE_LLM=0

# Optional mature local RAG retrieval. Requires the Python venv from local setup
# and an Ollama embedding model such as nomic-embed-text.
CCM_RAG_ENABLED=0
CCM_RAG_PYTHON=.venv-rag/bin/python
CCM_RAG_EMBED_MODEL=nomic-embed-text
CCM_RAG_K=12
CCM_RAG_TIMEOUT_MS=15000

# Shopping portal checks. This does not scrape Rakuten; it only adds a search entry link.
RAKUTEN_ENABLED=1
RAKUTEN_SEARCH_URL_TEMPLATE=https://www.rakuten.com/{domain}

# Credit-card news monitor. Defaults to Doctor of Credit's credit-card RSS feed.
DOC_MONITOR_URL=https://www.doctorofcredit.com/category/credit-cards/feed/
DOC_MONITOR_LIMIT=8
DOC_MONITOR_MIN_COMMENTS=20
DOC_MONITOR_CREDIT_CARD_MIN_COMMENTS=5
DOC_MONITOR_GROWTH_COMMENTS=100
